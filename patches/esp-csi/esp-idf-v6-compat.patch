index 209bba5..2da188d 100644
--- a/examples/esp-radar/console_test/CMakeLists.txt
+++ b/examples/esp-radar/console_test/CMakeLists.txt
@@ -11,3 +11,9 @@ project(${CURDIR})
 
 git_describe(PROJECT_VERSION ${COMPONENT_DIR})
 message("Project commit: " ${PROJECT_VERSION})
+
+# Workaround for ESP-IDF v6: managed component espressif/led_strip (2.5.5)
+# misses '#include "esp_heap_caps.h"' in led_strip_spi_dev.c, which no longer
+# gets included transitively. Force-include it without editing managed_components.
+idf_component_get_property(led_strip_lib espressif__led_strip COMPONENT_LIB)
+target_compile_options(${led_strip_lib} PRIVATE "-include" "esp_heap_caps.h")
