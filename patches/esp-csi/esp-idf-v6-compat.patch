diff --git a/examples/esp-radar/console_test/main/app_main.c b/examples/esp-radar/console_test/main/app_main.c
index e97733e..377e6e4 100644
--- a/examples/esp-radar/console_test/main/app_main.c
+++ b/examples/esp-radar/console_test/main/app_main.c
@@ -619,10 +619,13 @@ static void wifi_event_handler(void *arg, esp_event_base_t event_base,
     } else if (event_base == WIFI_EVENT && event_id == WIFI_EVENT_STA_DISCONNECTED) {
         g_wifi_connect_status = false;
         ESP_LOGW(TAG, "Wi-Fi disconnected");
-        esp_radar_config_t radar_config;
-        esp_radar_get_config(&radar_config);
-        esp_radar_wifi_reinit(&radar_config.wifi_config);
-
+        /* IDF v6 workaround: esp_radar_wifi_reinit() calls esp_radar_wifi_init()
+         * which re-runs esp_netif_create_default_wifi_sta() on every disconnect
+         * (unguarded). On IDF v6 this aborts with
+         * "esp_netif_new_api: ... duplicate key" and reboots the chip, causing a
+         * reconnect/crash loop. Wi-Fi and netif are already initialized, so just
+         * retry the association instead of re-initializing everything. */
+        esp_wifi_connect();
     }
 }
 esp_err_t ws2812_led_init(void)
